#!/bin/bash
# HARD BLOCK: Prevent pushing directly to main/master
# All changes must go through a branch + PR workflow.

while read local_ref local_sha remote_ref remote_sha; do
  if echo "$remote_ref" | grep -qE "refs/heads/(main|master)$"; then
    echo ""
    echo "🚫 BLOCKED: Pushing directly to main is not allowed."
    echo ""
    echo "   Create a branch and open a PR instead:"
    echo "   git checkout -b fix/your-description"
    echo "   git push -u origin fix/your-description"
    echo "   gh pr create"
    echo ""
    exit 1
  fi
done

exit 0
